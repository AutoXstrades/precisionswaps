generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum BuildGoal {
  DAILY
  STREET
  DRAG
  SHOW
}

enum AgentLogRole {
  system
  user
  assistant
}

enum AgentType {
  LS_SPECIALIST
  CLAWBOT_SUPERVISOR
  CLAWBOT_WORKER
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         UserRole   @default(CUSTOMER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  builds       Build[]
  agentLogs    AgentLog[]
}

model Build {
  id           String        @id @default(cuid())
  userId       String
  vehicleYear  Int
  vehicleMake  String
  vehicleModel String
  engineStatus String
  goal         BuildGoal
  notes        String?
  aiSummary    String?
  estimateMin  Int?
  estimateMax  Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentLogs    AgentLog[]
  customerLogs CustomerLog[]

  @@index([userId])
  @@index([createdAt])
}

model UniversalPartGroup {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String          @unique
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  parts     UniversalPart[]

  @@index([createdAt])
  @@map("universal_part_groups")
}

model UniversalPart {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId     String             @map("group_id") @db.Uuid
  name        String
  description String?
  approved    Boolean            @default(false)
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  group       UniversalPartGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, name])
  @@index([groupId])
  @@index([createdAt])
  @@index([approved])
  @@map("universal_parts")
}

model AdminNotification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type      String
  message   String
  metadata  Json?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([resolved])
  @@index([createdAt])
  @@map("admin_notifications")
}

model AgentLog {
  id        String       @id @default(cuid())
  userId    String?
  buildId   String?
  role      AgentLogRole
  content   String
  createdAt DateTime     @default(now())
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  build     Build?       @relation(fields: [buildId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([buildId])
  @@index([createdAt])
}

model AgentConfig {
  id         String    @id @default(cuid())
  name       String
  type       AgentType
  configJson Json
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([type])
}

model CustomerLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buildId     String   @map("build_id")
  senderRole  String   @map("sender_role")
  senderEmail String   @map("sender_email")
  message     String
  createdAt   DateTime @default(now()) @map("timestamp") @db.Timestamptz(6)
  reviewed    Boolean  @default(false)
  build       Build    @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@index([buildId])
  @@index([createdAt])
  @@map("customer_logs")
}
